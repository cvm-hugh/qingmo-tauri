{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/main/capability/schema.json",
  "identifier": "default",
  "description": "轻墨默认权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive"
  ]
}
